{
  "name": "commander-ai",
  "version": "0.1.0",
  "description": "AI 多实例实时指挥台 — 像皇帝批阅奏章一样管理你的 AI 工作流",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.3",
  "bin": {
    "commander": "./bin/commander.js",
    "cmd": "./bin/commander.js"
  },
  "scripts": {
    "serve": "node bin/commander.js serve",
    "dev:client": "vite",
    "build": "vite build",
    "test": "node --test test/*.test.mjs",
    "dev": "concurrently -n server,client -c blue,green \"node bin/commander.js serve\" \"vite\""
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}
